[sub_resource type="Resource" id="Resource_eq2ru"]
script = ExtResource("1_23jh0")
speaker = ExtResource("2_o5goh")
text = "The air here is dangerous. The perchlorate salts can damage your circuitry."
animation = &"sad"
metadata/_custom_type_script = "uid://b2364himxu4dy"

[sub_resource type="Resource" id="Resource_fh5dd"]
script = ExtResource("1_23jh0")
speaker = ExtResource("4_ae12w")
side = -1
text = "Of all the planets I could have landed on..."
animation = &"frustrated"
metadata/_custom_type_script = "uid://b2364himxu4dy"

[sub_resource type="Resource" id="Resource_ydf2d"]
script = ExtResource("1_23jh0")
speaker = ExtResource("4_ae12w")
side = -1
text = "I guess that's just my luck."
metadata/_custom_type_script = "uid://b2364himxu4dy"

[sub_resource type="Resource" id="Resource_r3w2l"]
script = ExtResource("1_23jh0")
speaker = ExtResource("2_o5goh")
text = "We cannot stay long. I shall try to get a sense of this place."
animation = &"look_down"
metadata/_custom_type_script = "uid://b2364himxu4dy"

[sub_resource type="Resource" id="Resource_6ihg1"]
script = ExtResource("1_23jh0")
speaker = ExtResource("2_o5goh")
text = "In the meantime, use the arrow keys to explore the area with caution."
