text = "[[MEASURING_DISTANCE]]"
metadata/_custom_type_script = "uid://b2364himxu4dy"

[sub_resource type="Resource" id="Resource_hyfpw"]
script = ExtResource("1_xelra")
speaker = ExtResource("2_6lltr")
text = "...You most definitely cannot cross that gap by simply jumping."
metadata/_custom_type_script = "uid://b2364himxu4dy"

[sub_resource type="Resource" id="Resource_7a5rv"]
script = ExtResource("1_xelra")
speaker = ExtResource("2_6lltr")
text = "Fret not. Give me a moment."
metadata/_custom_type_script = "uid://b2364himxu4dy"

[sub_resource type="Resource" id="Resource_qmoas"]
script = ExtResource("1_xelra")
speaker = ExtResource("2_6lltr")
text = "...There. I have programmed your suit to redirect toxic gases in the atmosphere to launch you forward."
metadata/_custom_type_script = "uid://b2364himxu4dy"

[sub_resource type="Resource" id="Resource_n7yde"]
script = ExtResource("1_xelra")
speaker = ExtResource("2_6lltr")
text = "This \"dash,\" as I call it, can be used in any direction."
metadata/_custom_type_script = "uid://b2364himxu4dy"

[sub_resource type="Resource" id="Resource_y0k3d"]
script = ExtResource("1_xelra")
speaker = ExtResource("2_6lltr")
text = "Simply press {dash} to use your \"dash.\""
metadata/_custom_type_script = "uid://b2364himxu4dy"

[sub_resource type="Resource" id="Resource_2t3l5"]
script = ExtResource("1_xelra")
speaker = ExtResource("3_mmh5p")
side = -1
text = "Thanks, brobot!"
metadata/_custom_type_script = "uid://b2364himxu4dy"

[sub_resource type="Resource" id="Resource_bfri0"]
script = ExtResource("1_xelra")
speaker = ExtResource("2_6lltr")
text = "Please do not call me that."
metadata/_custom_type_script = "uid://b2364himxu4dy"

