[sub_resource type="Resource" id="Resource_oxxdg"]
script = ExtResource("1_1i0qq")
speaker = ExtResource("2_kkyj4")
text = "...Though this is possible without other modifications..."
metadata/_custom_type_script = "uid://b2364himxu4dy"

[sub_resource type="Resource" id="Resource_gk35a"]
script = ExtResource("1_1i0qq")
speaker = ExtResource("2_kkyj4")
text = "You may find it easier to use your spacesuit's built-in backpack fabricator to redirect yourself while your gravity is disabled."
metadata/_custom_type_script = "uid://b2364himxu4dy"

[sub_resource type="Resource" id="Resource_gqfv8"]
script = ExtResource("1_1i0qq")
speaker = ExtResource("2_kkyj4")
text = "Use the fabricator to make a heavy object, and throw it in the opposite direction from where you want to travel towards."
metadata/_custom_type_script = "uid://b2364himxu4dy"

[sub_resource type="Resource" id="Resource_7igva"]
script = ExtResource("1_1i0qq")
speaker = ExtResource("2_kkyj4")
text = "Press C while your gravity is disabled to quickly perform this action."
metadata/_custom_type_script = "uid://b2364himxu4dy"

[sub_resource type="Resource" id="Resource_j2dxm"]
script = ExtResource("1_1i0qq")
speaker = ExtResource("3_as3gm")
side = -1
text = "Wait, I can make and throw anything?"
metadata/_custom_type_script = "uid://b2364himxu4dy"

[sub_resource type="Resource" id="Resource_yd7rt"]
script = ExtResource("1_1i0qq")
speaker = ExtResource("2_kkyj4")
text = "That would be correct."
metadata/_custom_type_script = "uid://b2364himxu4dy"

[sub_resource type="Resource" id="Resource_t8ynr"]
script = ExtResource("1_1i0qq")
speaker = ExtResource("3_as3gm")
side = -1
text = "Sweet! I'll use a wrench, like that one famous saying..."
metadata/_custom_type_script = "uid://b2364himxu4dy"

[sub_resource type="Resource" id="Resource_3xowk"]
script = ExtResource("1_1i0qq")
speaker = ExtResource("3_as3gm")
side = -1
text = "Uh... oh yeah! \"Throw a wrench in it!\" You know that one?"
metadata/_custom_type_script = "uid://b2364himxu4dy"

[sub_resource type="Resource" id="Resource_oyxpy"]
script = ExtResource("1_1i0qq")
speaker = ExtResource("2_kkyj4")
text = "...No."
metadata/_custom_type_script = "uid://b2364himxu4dy"

[sub_resource type="Resource" id="Resource_f0urn"]
script = ExtResource("1_1i0qq")
speaker = ExtResource("3_as3gm")
side = -1
text = "Oh... I'll show you what I'm talking about later, I guess..."
